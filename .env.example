# Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://jobpilot:jobpilot@localhost:5432/jobpilot

# LLM — Groq (recommended free tier) or Google Gemini
LLM_PROVIDER=groq
GROQ_API_KEY=
# GROQ_MODEL=openai/gpt-oss-120b

# Or Google:
# LLM_PROVIDER=google
# GOOGLE_GENERATIVE_AI_API_KEY=
# GEMINI_MODEL=gemini-3.5-flash

# Spacing between LLM calls (ms). Groq default ~2500; Gemini free tier ~13000.
# LLM_MIN_INTERVAL_MS=2500

# Real form submission (default is dry-run: fill + screenshot, no submit)
# AUTO_SUBMIT=1

# Optional HTTP Basic Auth for hosted deploys (unset for local)
# APP_PASSWORD=
